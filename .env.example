# Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Auth
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_URL=http://localhost:3000

# 钱包：当前仅用浏览器扩展 (Injected)，无需 WalletConnect/Reown
# 支持 Rainbow 扩展、MetaMask、Rabby 等

# Polymarket API
# 注意：Polymarket API 在中国大陆、美国等地区可能被封锁
# 需要使用 VPN 连接到欧洲或其他支持的地区才能访问真实市场数据
# Note: Users connect their own wallets and sign transactions client-side
# No server-side private key required
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_TIMEOUT=15000

# Polymarket Builder API (Optional - for order attribution and rewards)
# Get keys at: https://polymarket.com/settings?tab=builder
# POLYMARKET_BUILDER_API_KEY=
# POLYMARKET_BUILDER_SECRET=
# POLYMARKET_BUILDER_PASSPHRASE=

# WebSocket
NEXT_PUBLIC_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Intraday collector (Railway worker)
# 用 Railway 常驻采集短期市场（比赛、分钟级 BTC 等）的 1s K 线基础数据
INTRADAY_COLLECTOR_MAX_MARKETS=120
INTRADAY_COLLECTOR_SHORT_TERM_HOURS=36
INTRADAY_COLLECTOR_REFRESH_MS=300000
INTRADAY_COLLECTOR_RETENTION_HOURS=12
